# ── Mail API ──
ICHIN_SERVER_NAME=mail.ichin.local
ICHIN_LISTEN_ADDR=0.0.0.0:8080
ICHIN_TLS_CERT=/etc/ichin/cert.pem
ICHIN_TLS_KEY=/etc/ichin/key.pem
ICHIN_DB_PATH=/var/lib/ichin/db
ICHIN_STORAGE_PATH=/var/lib/ichin/storage
ICHIN_GATEWAY_ADDR=0.0.0.0:25

# ── Account Server ──
ICHIN_ACCOUNT_DATA_PATH=account_data

# ── Protocol: Ichin-DNS ──
ICHINDNS_SECRET=change-me-to-a-random-secret

# ── Logging (applied via RUST_LOG) ──
RUST_LOG=info
