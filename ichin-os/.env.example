# ── Mail API ──
ICHIN_SERVER_NAME=mail.ichin.local
ICHIN_LISTEN_ADDR=0.0.0.0:8080
ICHIN_TLS_CERT=/etc/ichin/cert.pem
ICHIN_TLS_KEY=/etc/ichin/key.pem
ICHIN_DB_PATH=/var/lib/ichin/db
ICHIN_STORAGE_PATH=/var/lib/ichin/storage
ICHIN_GATEWAY_ADDR=0.0.0.0:25

# ── Account Server ──
ICHIN_ACCOUNT_DATA_PATH=account_data

# ── Protocol: Ichin-DNS ──
ICHINDNS_SECRET=change-me-to-a-random-secret

# ── AI Router ──
AI_ROUTER_URL=http://localhost:8020
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLAMA_CPP_BASE_URL=http://localhost:8080

# ── Voice Engine ──
VOICE_ENGINE_URL=http://localhost:8030
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ── Browser Engine ──
BROWSER_ENGINE_URL=http://localhost:8040

# ── AI Metasearch ──
AI_METASEARCH_URL=http://localhost:8050
BRAVE_API_KEY=

# ── Mail AI ──
MAIL_AI_URL=http://localhost:8060

# ── Knowledge Graph ──
KNOWLEDGE_GRAPH_URL=http://localhost:8070
MEMORY_ENGINE_URL=http://localhost:8003

# ── Orchestrator ──
ORCHESTRATOR_URL=http://localhost:8000
AGENTS_URL=http://localhost:8012
AI_STUDIO_URL=http://localhost:8016

# ── Logging (applied via RUST_LOG) ──
RUST_LOG=info
